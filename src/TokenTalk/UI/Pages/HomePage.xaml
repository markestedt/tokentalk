<UserControl x:Class="TokenTalk.UI.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8F8F8">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <!-- Grid wrapper lets the StackPanel centre when the window is wide -->
        <Grid>
            <StackPanel MaxWidth="860" HorizontalAlignment="Center"
                        Margin="28,24">

                <!-- Header row -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Welcome back"
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#1C1C1E"/>
                        <TextBlock Text="Recent dictation activity"
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="14"
                                   Foreground="#8E8E93"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Stat chips -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,4,0,0">

                        <!-- Weeks streak -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <TextBlock Text="⭐" FontFamily="Segoe UI Emoji"
                                       FontSize="15" VerticalAlignment="Center"
                                       Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding WeeksStreakDisplay}"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="14" FontWeight="Medium"
                                       Foreground="#1C1C1E" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Total words -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <TextBlock Text="🚀" FontFamily="Segoe UI Emoji"
                                       FontSize="15" VerticalAlignment="Center"
                                       Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding TotalWordsDisplay}"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="14" FontWeight="Medium"
                                       Foreground="#1C1C1E" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Words per minute -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏅" FontFamily="Segoe UI Emoji"
                                       FontSize="15" VerticalAlignment="Center"
                                       Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding AvgWpmDisplay}"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="14" FontWeight="Medium"
                                       Foreground="#1C1C1E" VerticalAlignment="Center"/>
                        </StackPanel>

                    </StackPanel>
                </Grid>

                <!-- Grouped feed -->
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>

                                <!-- Date group header -->
                                <TextBlock Text="{Binding Label}"
                                           Style="{StaticResource DateGroupHeaderStyle}"/>

                                <!-- Rows: bordered container, no fill, items separated by dividers -->
                                <Border BorderBrush="#DCDCE0"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Background="Transparent"
                                        ClipToBounds="True"
                                        Margin="0,0,0,16">
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#DCDCE0"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="16,14">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="70"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding TimeDisplay}"
                                                                   Foreground="#8E8E93"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="13"
                                                                   VerticalAlignment="Top"
                                                                   Margin="0,2,0,0"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Text}"
                                                                   Foreground="#1C1C1E"
                                                                   FontFamily="{StaticResource AppFont}"
                                                                   FontSize="14"
                                                                   TextWrapping="Wrap"/>
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                            <Button Content="⎘"
                                                                    Tag="{Binding Text}"
                                                                    Style="{StaticResource CopyButtonStyle}"
                                                                    Click="Copy_Click"
                                                                    ToolTip="Copy to clipboard"/>
                                                            <Button Content="×"
                                                                    Tag="{Binding Id}"
                                                                    Style="{StaticResource CopyButtonStyle}"
                                                                    Click="Delete_Click"
                                                                    ToolTip="Delete"
                                                                    Margin="4,0,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <TextBlock Text="No dictations yet. Press the hotkey to start recording."
                           FontFamily="{StaticResource AppFont}"
                           FontSize="14"
                           Foreground="#8E8E93"
                           HorizontalAlignment="Center"
                           Margin="0,40">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Groups.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
