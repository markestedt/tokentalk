<UserControl x:Class="TokenTalk.UI.Pages.DictionaryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8F8F8">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">

            <!-- Header -->
            <TextBlock Text="Dictionary"
                       FontFamily="{StaticResource AppFont}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#1C1C1E"
                       Margin="0,0,0,4"/>
            <TextBlock FontFamily="{StaticResource AppFont}" FontSize="14"
                       Foreground="#8E8E93" Margin="0,0,0,20" TextWrapping="Wrap">
                <Run Text="Simple terms"/>
                <Run Text=" teach the transcription model how to spell a word (e.g. a product name). "/>
                <Run Text="Mappings"/>
                <Run Text=" replace a mishearing with the correct value after transcription."/>
            </TextBlock>

            <!-- Add entry card -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="ADD ENTRY"
                               Style="{StaticResource SectionLabelStyle}"
                               Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Style="{StaticResource InputStyle}"
                                 Text="{Binding NewOriginal, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Mishearing (optional)"
                                 KeyDown="Input_KeyDown"/>

                        <TextBlock Grid.Column="1"
                                   Text="→"
                                   VerticalAlignment="Center"
                                   Margin="12,0"
                                   FontSize="17"
                                   Foreground="#8E8E93"/>

                        <TextBox Grid.Column="2"
                                 Style="{StaticResource InputStyle}"
                                 Text="{Binding NewReplacement, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Term / correction"
                                 KeyDown="Input_KeyDown"/>

                        <Button Grid.Column="3"
                                Content="Add"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="12,0,0,0"
                                Click="Add_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Entries list -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="ENTRIES"
                               Style="{StaticResource SectionLabelStyle}"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="No entries yet. Add some above."
                               FontFamily="{StaticResource AppFont}"
                               FontSize="14"
                               Foreground="#8E8E93"
                               Margin="0,8">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Entries.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Mapping: [Original →] shown only for IsMapping entries -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMapping}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Border Background="#F8F8F8" CornerRadius="6" Padding="10,6">
                                            <TextBlock Text="{Binding Original}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="14"/>
                                        </Border>
                                        <TextBlock Text="→"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="#8E8E93"/>
                                    </StackPanel>

                                    <!-- Replacement (always shown) -->
                                    <Border Grid.Column="1"
                                            Background="#F8F8F8"
                                            CornerRadius="6"
                                            Padding="10,6">
                                        <TextBlock Text="{Binding Replacement}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="14"/>
                                    </Border>

                                    <Button Grid.Column="2"
                                            Content="×"
                                            Style="{StaticResource CopyButtonStyle}"
                                            Margin="8,0,0,0"
                                            Click="Delete_Click"
                                            Tag="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
