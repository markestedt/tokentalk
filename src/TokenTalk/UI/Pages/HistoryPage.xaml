<UserControl x:Class="TokenTalk.UI.Pages.HistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8F8F8">

    <DockPanel>

        <!-- Header -->
        <Grid DockPanel.Dock="Top" Margin="28,24,28,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="History"
                       FontFamily="{StaticResource AppFont}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#1C1C1E"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="Refresh"
                    Style="{StaticResource GhostButtonStyle}"
                    Click="Refresh_Click"/>
        </Grid>

        <!-- Pagination bar -->
        <Border DockPanel.Dock="Bottom" Margin="28,12,28,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="← Prev"
                        Style="{StaticResource GhostButtonStyle}"
                        IsEnabled="{Binding CanGoPrev}"
                        Click="Prev_Click"
                        Margin="0,0,8,0"/>
                <TextBlock VerticalAlignment="Center" FontFamily="{StaticResource AppFont}" FontSize="14"
                           Foreground="#8E8E93">
                    <Run Text="Page "/>
                    <Run Text="{Binding CurrentPage, Converter={StaticResource OneIndexConverter}, Mode=OneWay}"/>
                    <Run Text=" of "/>
                    <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                </TextBlock>
                <Button Content="Next →"
                        Style="{StaticResource GhostButtonStyle}"
                        IsEnabled="{Binding CanGoNext}"
                        Click="Next_Click"
                        Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Centered content container — max 860px, full-width on small screens -->
        <Grid>
            <Border MaxWidth="860" HorizontalAlignment="Center"
                    BorderBrush="#DCDCE0" BorderThickness="1"
                    Background="Transparent" CornerRadius="12"
                    ClipToBounds="True"
                    Margin="28,0,28,0">
                <DockPanel>

                    <!-- Column header row -->
                    <Grid DockPanel.Dock="Top"
                          Margin="16,10,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TIME"
                                   FontFamily="{StaticResource AppFont}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#8E8E93"/>
                        <TextBlock Grid.Column="1" Text="WORDS"
                                   FontFamily="{StaticResource AppFont}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#8E8E93"/>
                        <TextBlock Grid.Column="2" Text="TRANSCRIPTION"
                                   FontFamily="{StaticResource AppFont}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#8E8E93"/>
                        <TextBlock Grid.Column="3" Text=""
                                   Width="52"/>
                    </Grid>

                    <Rectangle DockPanel.Dock="Top" Height="1"
                               Fill="#DCDCE0" Margin="0,8,0,0"/>

                    <!-- Items -->
                    <ListView ItemsSource="{Binding Items}"
                              BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#DCDCE0"/>
                                <Setter Property="Padding" Value="16,14"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F8F8FA"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TimeDisplay}"
                                               Foreground="#8E8E93"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="13"
                                               VerticalAlignment="Top"
                                               Margin="0,2,0,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding WordCount}"
                                               Foreground="#8E8E93"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="13"
                                               VerticalAlignment="Top"
                                               Margin="0,2,0,0"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Text}"
                                               Foreground="#1C1C1E"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="14"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                                        <Button Content="⎘"
                                                Tag="{Binding Text}"
                                                Style="{StaticResource CopyButtonStyle}"
                                                Click="Copy_Click"
                                                ToolTip="Copy to clipboard"/>
                                        <Button Content="×"
                                                Tag="{Binding Id}"
                                                Style="{StaticResource CopyButtonStyle}"
                                                Click="Delete_Click"
                                                ToolTip="Delete"
                                                Margin="4,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </DockPanel>
            </Border>
        </Grid>

    </DockPanel>
</UserControl>
